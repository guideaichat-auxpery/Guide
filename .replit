modules = ["python-3.11", "nodejs-20", "python3", "postgresql-16"]

[nix]
channel = "stable-25_05"
packages = ["cargo", "freetype", "glibcLocales", "lcms2", "libiconv", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "rustc", "tcl", "tesseract", "tk", "zlib"]

[deployment]
deploymentTarget = "autoscale"
run = ["sh", "-c", "bash start_all.sh"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Guide AI Assistant"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Adaptive Learning Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Payments Service"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Reverse Proxy"

[[workflows.workflow]]
name = "Guide AI Assistant"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "streamlit run app.py --server.port 8080"
waitForPort = 8080

[[workflows.workflow]]
name = "Adaptive Learning Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node adaptive/server.js"
waitForPort = 3000

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Payments Service"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node payments/server.js"
waitForPort = 3001

[[workflows.workflow]]
name = "Reverse Proxy"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node proxy_server.js"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 3000
externalPort = 4200

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 3100
externalPort = 3002

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8501
externalPort = 3000

[agent]
integrations = ["web_scraper:1.0.0", "python_openai:1.0.0", "python_openai:1.0.0"]

[userenv]

[userenv.development]
STRIPE_MONTHLY_PRICE_ID = "price_1Sd7RX8PGiRAuUvfzibxCNLV"
STRIPE_ANNUAL_PRICE_ID = "price_1SeSbY8PGiRAuUvf0xjZmMXK"

[userenv.production]
STRIPE_MONTHLY_PRICE_ID = "price_1Sd7RX8PGiRAuUvfzibxCNLV"
STRIPE_ANNUAL_PRICE_ID = "price_1SeSbY8PGiRAuUvf0xjZmMXK"

