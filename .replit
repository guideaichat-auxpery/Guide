modules = ["python-3.11", "nodejs-20", "postgresql-16", "python3"]

[nix]
channel = "stable-25_05"
packages = ["cargo", "freetype", "glibcLocales", "lcms2", "libiconv", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "rustc", "tcl", "tesseract", "tk", "zlib"]

[deployment]
deploymentTarget = "autoscale"
run = ["streamlit", "run", "app.py", "--server.port", "5000"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Guide AI Assistant"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Adaptive Learning Server"

[[workflows.workflow]]
name = "Guide AI Assistant"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "streamlit run app.py --server.port 5000"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Adaptive Learning Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node adaptive/server.js"
waitForPort = 3000

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 3000
externalPort = 4200

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 33927
externalPort = 3001

[[ports]]
localPort = 34841
externalPort = 3003

[[ports]]
localPort = 36901
externalPort = 3002

[[ports]]
localPort = 39691
externalPort = 5173

[[ports]]
localPort = 43237
externalPort = 3000

[[ports]]
localPort = 44671
externalPort = 5000

[[ports]]
localPort = 44765
externalPort = 6000

[agent]
integrations = ["web_scraper==1.0.0", "python_openai==1.0.0==1.0.0", "python_openai==1.0.0"]
