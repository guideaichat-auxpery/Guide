modules = ["python-3.11", "nodejs-20", "python3", "postgresql-16"]

[nix]
channel = "stable-25_05"
packages = ["cargo", "freetype", "glibcLocales", "lcms2", "libiconv", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "rustc", "tcl", "tesseract", "tk", "zlib"]

[deployment]
deploymentTarget = "static"
build = ["npm", "run", "build"]
publicDir = "dist"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Adaptive Learning Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Guide API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Frontend Dev Server"

[[workflows.workflow]]
name = "Adaptive Learning Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node adaptive/server.js"
waitForPort = 3000

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Guide API Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "uvicorn api.main:app --host 0.0.0.0 --port 8000 --reload"
waitForPort = 8000

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Frontend Dev Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && npx vite --host 0.0.0.0 --port 5000"
waitForPort = 5000

[[ports]]
localPort = 3000
externalPort = 4200

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 3100
externalPort = 3002

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5173
externalPort = 5173

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8501
externalPort = 3000

[agent]
integrations = ["web_scraper:1.0.0", "python_openai:1.0.0", "python_openai:1.0.0", "resend:1.0.0"]

[userenv]

[userenv.development]
STRIPE_MONTHLY_PRICE_ID = "price_1Sd7RX8PGiRAuUvfzibxCNLV"
STRIPE_ANNUAL_PRICE_ID = "price_1SeSbY8PGiRAuUvf0xjZmMXK"

[userenv.production]
STRIPE_MONTHLY_PRICE_ID = "price_1Sd7RX8PGiRAuUvfzibxCNLV"
STRIPE_ANNUAL_PRICE_ID = "price_1SeSbY8PGiRAuUvf0xjZmMXK"
VITE_API_URL = "https://guide-2pwx.onrender.com/api"

[userenv.shared]
PAYMENTS_API_SECRET = "f898a5ea592454e66e3a38fb6cff4992888e515e8a4b3becda362431a42c5431"
ADMIN_PASSWORD = "Testtest"
STRIPE_SCHOOL_SEAT_PRICE_ID = "price_1SteED8PGiRAuUvflyL4Hqr2"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000
